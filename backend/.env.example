# Backend Environment Variables
# Copy this file to .env and fill in your values

# MongoDB connection
MONGO_URL=mongodb://localhost:27017
DB_NAME=mantez_reels
# MONGO_TLS=1  # Uncomment to enable TLS for MongoDB connections

# Authentication
JWT_SECRET_KEY=generate-a-strong-random-secret-here
# ADMIN_INITIAL_PASSWORD=  # Set this to control initial admin password (random if unset)
# ADMIN_EMAIL=admin@yourdomain.com

# CORS (comma-separated origins, or * for development)
CORS_ORIGINS=http://localhost:3000

# Media storage
MEDIA_DIR=/tmp/backend/media

# IP forwarding (number of trusted reverse proxies)
TRUSTED_PROXY_COUNT=1

# Optional: Cloud storage (Cloudflare R2 / S3-compatible)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=

# Optional: Email service
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=
