{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "yarn", "start"],
      "port": 3000,
      "cwd": "frontend"
    },
    {
      "name": "backend",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "python", "-m", "uvicorn", "server:app", "--reload", "--port", "8001"],
      "port": 8001,
      "cwd": "backend"
    }
  ]
}
